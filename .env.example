# Public domain Traefik will route to this app (e.g. amico.example.com)
APP_DOMAIN=

# Name of the external Docker network Traefik is running on
TRAEFIK_NETWORK=traefik

# Name of the cert resolver configured in your Traefik instance
TRAEFIK_CERTRESOLVER=le

# Hugging Face token for speaker diarization (optional)
HF_TOKEN=
